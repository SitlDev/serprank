{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "public": true,
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL",
      "required": true
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "${VITE_API_URL}/api/$1"
    }
  ]
}
