# Server
NODE_ENV=development
PORT=3000

# Database
# Option 1: Using DATABASE_URL (recommended for Railway/production)
DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: Using individual parameters (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clearserp_db
DB_USER=clearserp
DB_PASSWORD=clearserp_dev

# Redis
REDIS_URL=redis://default:password@host:6379

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=7d

# SERP API (Required for live search)
# Get your free API key at: https://serper.dev
# Free tier: 100 searches/month, then $10/month for 500 searches
SERPER_API_KEY=your-serper-api-key-here

# Trending Keywords APIs
# Search Engines - Get API keys from:
BING_SEARCH_API_KEY=your-bing-api-key
YANDEX_API_KEY=your-yandex-api-key
BAIDU_API_KEY=your-baidu-api-key
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Social & Commerce APIs
TWITTER_API_KEY=your-twitter-api-key
YOUTUBE_API_KEY=your-youtube-api-key
TIKTOK_API_KEY=your-tiktok-api-key
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id
PINTEREST_ACCESS_TOKEN=your-pinterest-access-token
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASSWORD=your_password

# Frontend URL
FRONTEND_URL=http://localhost:5173
